# Go 后端配置。
# PowerShell 临时设置示例：
#   $env:PORT="8000"; go run ./cmd/server

PORT=8000

# 默认读取 backend-go/data 下的 Markdown 攻略数据。
DATA_DIR=data

# 当前使用 JSON 文件保存行程。
STORAGE_FILE=data/trips.json

# 可选：配置后会调用 OpenAI-compatible Chat Completions。
# 不配置时使用 RulePlanner，仍然可以完整跑通生成、保存、历史和导出 Markdown。
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
LLM_TIMEOUT_SECONDS=60

# 可选：配置后会调用高德 Web 服务补充地址、经纬度、POI ID 和图片。
ENABLE_AMAP_ENRICHMENT=false
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com/v3

# 可选：开启在线攻略研究工具。
# WEB_SEARCH_ENDPOINT 需要返回 JSON，内部任意层级包含 url/link/href 字段即可。
# 例：自建搜索服务 / Tavily / SerpAPI / Bing Search 代理都可以适配。
ENABLE_WEB_RESEARCH=false
WEB_SEARCH_ENDPOINT=
WEB_SEARCH_API_KEY=
WEB_RESEARCH_TIMEOUT_SECONDS=20
WEB_RESEARCH_MAX_PAGES=3
