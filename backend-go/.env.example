# Go 后端配置。
# PowerShell 临时设置示例：
#   $env:PORT="8000"; go run ./cmd/server

PORT=8000

# 默认读取 backend-go/data 下的 Markdown 攻略数据。
DATA_DIR=data

# 当前使用 JSON 文件保存行程。
STORAGE_FILE=data/trips.json

# Agent 编排模式：
# - tool: 默认，使用 OpenAI-compatible tool-calling agent，缺少 LLM key 时自动兜底
# - multi: 使用 Go 原生链式多 agent 编排
# - default: 使用固定步骤兜底 agent
AGENT_MODE=tool

# 可选：本地/向量检索配置。Go 代码使用 Qdrant HTTP REST API，端口应为 6333。
RAG_BACKEND=markdown
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=travel_guides

# 可选：配置后会调用 OpenAI-compatible Chat Completions。
# 不配置时使用 RulePlanner，仍然可以完整跑通生成、保存、历史和导出 Markdown。
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
LLM_TIMEOUT_SECONDS=60

# 可选：配置后会调用高德 Web 服务补充地址、经纬度、POI ID 和图片。
ENABLE_AMAP_ENRICHMENT=false
ENABLE_AMAP_ROUTING=false
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com/v3
AMAP_BASE_V5_URL=https://restapi.amap.com/v5

# 可选：开启在线攻略研究工具。
# WEB_SEARCH_ENDPOINT 需要返回 JSON，内部任意层级包含 url/link/href 字段即可。
# 例：自建搜索服务 / Tavily / SerpAPI / Bing Search 代理都可以适配。
ENABLE_WEB_RESEARCH=false
# tavily uses WEB_SEARCH_API_KEY and defaults to https://api.tavily.com/search.
# custom keeps the old WEB_SEARCH_ENDPOINT-compatible search proxy behavior.
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_ENDPOINT=
WEB_SEARCH_API_KEY=
WEB_RESEARCH_TIMEOUT_SECONDS=20
WEB_RESEARCH_MAX_PAGES=3
